{
  "search_url_template": "https://www.gequhai.com/s/{query}",
  "search_result_links": [
    "#myTables > tbody > tr:nth-child(1) > td:nth-child(2) > a"
  ],
  "detail_download_buttons": [
    "#btn-download-mp3",
    "a:has-text('下载歌曲')",
    "text=下载"
  ],
  "quality_download_buttons": [
    "#btn-download-mp3[href]",
    "a[href*='pan.quark.cn']",
    "a:has-text('下载歌曲')"
  ],
  "storage_row_selectors": [
    "tbody tr",
    ".ant-table-tbody > tr",
    ".ant-table-row",
    "[role='row']"
  ],
  "row_name_selectors": [
    ".filename-text",
    ".file-name",
    ".filename",
    ".file-click-wrap",
    "td:nth-child(2)"
  ],
  "row_size_selectors": [
    "td:nth-child(3)",
    "td:nth-child(4)",
    ".file-size",
    "[data-role='size']"
  ],
  "row_download_selectors": [
    ".hoitem-down",
    ".share-hover-menu-download"
  ],
  "pre_download_confirm_buttons": [
    "body > div.jconfirm.jconfirm-light.jconfirm-open > div.jconfirm-scrollpane > div > div > div > div > div > div > div > div.jconfirm-buttons",
    "text=确定"
  ],
  "post_download_confirm_buttons": [],
  "post_quality_close_buttons": [
    "body > div:nth-child(10) > div > div.ant-modal-wrap.ant-modal-centered > div > div.ant-modal-content > button"
  ],
  "directory_name_pattern": "^\\d+$",
  "max_depth": 2,
  "expect_new_page_after_result_click": false,
  "expect_new_page_after_quality_click": true,
  "timeout_ms": 15000
}
